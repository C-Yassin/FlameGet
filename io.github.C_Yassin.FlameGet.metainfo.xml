<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>io.github.C_Yassin.FlameGet</id>
    <metadata_license>FSFAP</metadata_license>
    <project_license>MIT</project_license>
    <name>FlameGet</name>
    <summary>Manage and accelerate your downloads</summary>
    
    <description>
        <p>Accelerate your downloads, grab videos from your favorite sites, and manage everything from a beautiful, modern interface.</p>
        <ul>
            <li>Clean, simple, and easy-to-use interface</li>
            <li>Support for BitTorrent and Magnet links</li>
            <li>Support for video links</li>
            <li>Selective file downloading for torrents</li>
            <li>Automatic daily tracker list updates</li>
            <li>Customizable User-Agent</li>
            <li>Customizable post-downlad commands</li>
            <li>System notifications upon download completion</li>
            <li>System tray integration for quick access</li>
            <li>Native CSS customization mode support</li>
            <li>Optionally delete downloaded files when removing tasks</li>
            <li>Available in multiple languages</li>
        </ul>
    </description>
    
    <launchable type="desktop-id">io.github.C_Yassin.FlameGet.desktop</launchable>
    <content_rating type="oars-1.1"/>
    
    <branding>
        <color type="primary" scheme_preference="light">#5E35B1</color>
